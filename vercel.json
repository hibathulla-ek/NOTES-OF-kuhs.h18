{
  "rewrites": [
    {
      "source": "/(.*)",
      "has": [{ "type": "header", "key": "sec-fetch-mode", "value": "navigate" }],
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ]
}
